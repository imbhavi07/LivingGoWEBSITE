generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  phone              String?
  passwordHash       String
  role               Role
  interns            Intern[]           @relation("SupervisorInterns")
  status             UserStatus         @default(active)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  ownerType          String?
  aadhaarNumber      String?
  aadhaarFrontUrl    String?
  aadhaarBackUrl     String?
  legalAcceptedAt    DateTime?
  verificationStatus VerificationStatus @default(not_required)
  reviewedAt         DateTime?
  clerkId            String?            @unique
  dob                DateTime?
  mobileNumber       String?
  instagramHandle    String?
  xHandle            String?
  university         String?
  courseYear         String?
  gender             String?
  emergencyContact   String?
  properties         Property[]         @relation("OwnerProperties")
  referral           Referral?
  tenantResidence    TenantResidence?
  tokenPayments      TokenPayment[]     @relation("StudentTokenPayments")
  wishlist           Wishlist[]
  visits             Visit[]            @relation("UserVisits")
  reviews            Review[]           @relation("StudentReviews") // Relation added for studentId

  @@index([clerkId])
  @@index([role])
  @@index([status])
  @@index([verificationStatus])
  @@index([createdAt])
}

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  verifiedAt DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model Property {
  id                    String             @id @default(cuid())
  ownerId               String?
  title                 String
  description           String
  price                 Int
  location              String
  roomType              RoomType
  preference            GenderPreference
  facilities            String[]
  status                PropertyStatus     @default(pending)
  source                ListingSource      @default(ONBOARDED)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  priceSingle           Int?
  bedsSingle            Int?
  priceDouble           Int?
  bedsDouble            Int?
  priceTriple           Int?
  bedsTriple            Int?
  securityDepositMonths String?
  sharedType            String?
  mealPlan              String?
  mealTimes             String[]
  curfewTime            String?
  noticePeriod          String?
  rulesStrictness       String?
  lat                   Float?
  lng                   Float?
  nearbyPlaces          Json?
  occupiedBeds          Int                @default(0)
  managerContact        String?            @db.VarChar(255)
  securityContact       String?            @db.VarChar(255)
  isFeatured            Boolean            @default(false)
  propertyCode          String?            @unique
  manualOwnerName       String?            // For manually listed properties (SUPER_ADMIN)
  owner                 User?              @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  images                PropertyImage[]
  panoramas             PropertyPanorama[]
  reviews               Review[]           @relation("PropertyReviews")
  tenants               TenantResidence[]
  tokenPayments         TokenPayment[]
  wishlistedBy          Wishlist[]
  visits                Visit[]            @relation("PropertyVisits")

  @@index([ownerId])
  @@index([status])
  @@index([location])
  @@index([price])
  @@index([createdAt])
}

model PropertyImage {
  id           String   @id @default(cuid())
  propertyId   String
  url          String
  publicId     String?
  createdAt    DateTime @default(now())
  roomCategory String?
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyPanorama {
  id           String   @id @default(cuid())
  propertyId   String
  title        String
  imageUrl     String
  publicId     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  roomCategory String?
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Review {
  id               String   @id @default(cuid())
  propertyId       String
  studentId        String?  // Made optional so Admin proxy reviews don't crash
  studentName      String?  // For admin proxy names
  isAdminGenerated Boolean  @default(false)
  cleanliness      Int      @default(0) // Mapped from actual schema needs
  food             Int      @default(0)
  security         Int      @default(0)
  management       Int      @default(0)
  location         Int      @default(0)
  comment          String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  property         Property @relation("PropertyReviews", fields: [propertyId], references: [id], onDelete: Cascade)
  student          User?    @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([studentId])
}

model TenantResidence {
  id         String   @id @default(cuid())
  studentId  String   @unique
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model TokenPayment {
  id               String             @id @default(cuid())
  studentId        String
  propertyId       String
  amount           Int
  utrNumber        String
  status           TokenPaymentStatus @default(pending)
  visitOtp         String?
  visitVerified    Boolean            @default(false)
  rentSettled      Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  moveInRequested  Boolean            @default(false)
  selectedRoomType RoomType?
  appliedCode      String?
  payeeName        String?
  payeePhone       String?
  payeeUpi         String?
  property         Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student          User               @relation("StudentTokenPayments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@index([studentId])
  @@index([propertyId])
  @@index([status])
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  discountType DiscountType
  value        Int
  validFrom    DateTime
  validTo      DateTime
  targetPlans  String[]
  isActive     Boolean      @default(true)
  maxUses      Int?
  currentUses  Int          @default(0)
  affiliateId  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([code])
  @@index([affiliateId])
}

model Referral {
  id         String         @id @default(cuid())
  userId     String         @unique
  code       String         @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  earnings   Float          @default(0)
  invites    Int            @default(0)
  successful Int            @default(0)
  status     ReferralStatus @default(PENDING)
  upiId      String?
  name       String?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Visit {
  id                  String        @id @default(cuid())
  tokenId             String        @unique
  studentId           String
  propertyId          String
  assignedLeadId      String?
  intern              Intern?       @relation(fields: [assignedLeadId], references: [id])
  meetingPointId      String?
  visitDate           DateTime
  timeSlot            String
  visitOtp            String
  visitOtpVerified    Boolean       @default(false)
  couponCode          String?
  referralCounted     Boolean       @default(false) 
  leadStatus          VisitStatus   @default(SCHEDULED)
  notes               String?
  whatsappNumber      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  student             User          @relation("UserVisits", fields: [studentId], references: [id])
  property            Property      @relation("PropertyVisits", fields: [propertyId], references: [id])
  isLocked            Boolean       @default(false)
  @@index([studentId])
  @@index([propertyId])
  @@index([tokenId])
  @@index([leadStatus])
}

enum VisitStatus {
  SCHEDULED
  ASSIGNED
  NOT_MET
  MET
  SUCCESSFUL
  NOT_SUCCESSFUL
  INTERESTED_OTHER_PROPERTY
}

enum Role {
  student
  owner
  admin
  SUPER_ADMIN
  PARTNER
  SUPERVISOR
  INTERN
}

enum UserStatus {
  active
  suspended
}

enum VerificationStatus {
  not_required
  pending_email_verification
  pending_approval
  approved
  rejected
}

enum RoomType {
  Single
  Shared
}

enum GenderPreference {
  Boys
  Girls
  Any
}

enum PropertyStatus {
  pending
  approved
  rejected
  inactive
}

enum TokenPaymentStatus {
  pending
  approved
  rejected
}

enum DiscountType {
  FLAT
  PERCENTAGE
  FIXED
}

enum ReferralStatus {
  PENDING
  COMPLETED
  CANCELLED
  APPROVED
  REJECTED
}

enum ListingSource {
  ONBOARDED
  LISTED
}

model Intern {
  id String @id @default(cuid())
  supervisorId String
  supervisor User @relation("SupervisorInterns", fields: [supervisorId], references: [id])
  name String
  phone String
  username String @unique
  passwordHash String
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visits Visit[]
}