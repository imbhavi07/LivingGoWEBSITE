generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  phone              String?
  passwordHash       String
  role               Role               @default(student)
  status             UserStatus         @default(active)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  ownerType          String?
  aadhaarNumber      String?
  aadhaarFrontUrl    String?
  aadhaarBackUrl     String?
  legalAcceptedAt    DateTime?
  verificationStatus VerificationStatus @default(not_required)
  reviewedAt         DateTime?
  clerkId            String?            @unique
  dob                DateTime?
  mobileNumber       String?
  instagramHandle    String?
  xHandle            String?
  university         String?
  courseYear         String?
  gender             String?
  emergencyContact   String?
  properties         Property[]         @relation("OwnerProperties")
  reviews            Review[]
  tenantResidence    TenantResidence?
  tokenPayments      TokenPayment[]     @relation("StudentTokenPayments")
  wishlist           Wishlist[]

  @@index([clerkId])
  @@index([role])
  @@index([status])
  @@index([verificationStatus])
  @@index([createdAt])
  couponsOwned         Coupon[]            @relation("CouponOwner")
  couponsRequested     Coupon[]            @relation("CouponRequestedBy")
  couponRedemptions    CouponRedemption[]  @relation("CouponRedeemer")
  referralsMade        Referral[]          @relation("ReferralsMade")
  referralsReceived    Referral[]          @relation("ReferralsReceived")
  affiliateProfile     AffiliateProfile?
}

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  verifiedAt DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model Property {
  id                    String            @id @default(cuid())
  ownerId               String
  title                 String
  description           String
  price                 Int
  location              String
  roomType              RoomType
  preference            GenderPreference
  facilities            String[]
  status                PropertyStatus    @default(pending)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  priceSingle           Int?
  bedsSingle            Int?
  priceDouble           Int?
  bedsDouble            Int?
  priceTriple           Int?
  bedsTriple            Int?
  securityDepositMonths String?
  isFeatured            Boolean           @default(false)
  sharedType            String?
  mealPlan              String?
  mealTimes             String[]
  curfewTime            String?
  noticePeriod          String?
  rulesStrictness       String?
  lat                   Float?
  lng                   Float?
  nearbyPlaces          Json?
  occupiedBeds          Int               @default(0)
  managerContact        String?           @db.VarChar(255)
  securityContact       String?           @db.VarChar(255)
  owner                 User              @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  images                PropertyImage[]
  panoramas             PropertyPanorama[]
  reviews               Review[]
  tenants               TenantResidence[]
  tokenPayments         TokenPayment[]
  wishlistedBy          Wishlist[]

  @@index([ownerId])
  @@index([status])
  @@index([location])
  @@index([price])
  @@index([createdAt])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  publicId   String?
  createdAt  DateTime @default(now())
  roomCategory String?
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyPanorama {
  id         String   @id @default(cuid())
  propertyId String

  title      String
  imageUrl   String
  publicId   String?
  sortOrder  Int      @default(0)

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomCategory String?
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Review {
  id          String   @id @default(cuid())
  studentId   String
  propertyId  String
  cleanliness Int
  food        Int
  security    Int
  management  Int
  location    Int
  comment     String?
  createdAt   DateTime @default(now())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@index([studentId])
  @@index([propertyId])
}

model TenantResidence {
  id         String   @id @default(cuid())
  studentId  String   @unique
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model TokenPayment {
  id              String             @id @default(cuid())
  studentId       String
  propertyId      String
  selectedRoomType RoomType?
  amount          Int
  utrNumber       String

  status          TokenPaymentStatus @default(pending)

  visitOtp        String?
  visitVerified   Boolean            @default(false)
  rentSettled     Boolean            @default(false)
  moveInRequested Boolean            @default(false)
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  student         User @relation("StudentTokenPayments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@index([studentId])
  @@index([propertyId])
  @@index([status])
}

enum Role {
  student
  owner
  admin
  SUPER_ADMIN
  CREATOR
}

enum UserStatus {
  active
  suspended
}

enum VerificationStatus {
  not_required
  pending_email_verification
  pending_approval
  approved
  rejected
}

enum RoomType {
  Single
  Shared
}

enum GenderPreference {
  Boys
  Girls
  Any
}

enum PropertyStatus {
  pending
  approved
  rejected
  inactive
}

enum TokenPaymentStatus {
  pending
  approved
  rejected
}

// ============================================================================
// LivingGo — Monetization Layer: Coupons + Refer-to-Earn
// Append these models to your existing schema.prisma (same datasource/generator).
// Assumes a pre-existing `User` model with `id`, `email`, `role`, `bookings`.
// ============================================================================

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum DiscountType {
  FLAT        // Fixed INR amount off
  PERCENTAGE  // % off, typically capped by maxDiscountAmount
}

enum CouponStatus {
  PENDING_APPROVAL // Submitted by a non-admin creator/student, awaiting Super Admin
  ACTIVE
  PAUSED           // Admin can freeze without deleting (preserves history/analytics)
  EXPIRED
  REJECTED
  ARCHIVED
}

enum CouponOwnerType {
  SYSTEM       // Global promo issued directly by Super Admin, no owner payout
  STUDENT      // Tenant-generated referral code
  CREATOR      // Influencer/content-creator code
  AFFILIATE    // Independent affiliate code
}

enum RoomCategory {
  SINGLE_SHARING
  DOUBLE_SHARING
  TRIPLE_SHARING
  STUDIO
  FULL_FLAT
  ALL // wildcard — applies to every category
}

enum ReferralStatus {
  CLICKED       // Link/code was used to land on the platform (attribution event)
  SIGNED_UP     // Referred user created an account
  BOOKED        // Referred user completed a paid booking (conversion)
  PAYOUT_LOCKED // Booking is inside the cancellation/chargeback risk window
  PAYOUT_READY  // Cleared risk window, eligible for payout batch
  PAID          // Payout disbursed
  VOIDED        // Fraud/abuse/self-referral — permanently disqualified
}

enum PayoutMethod {
  BANK_TRANSFER
  UPI
}

enum AffiliateStatus {
  PENDING_REVIEW
  APPROVED
  SUSPENDED
  REJECTED
}

enum LedgerEntryType {
  EARNED_PENDING   // Conversion happened, still inside lock window
  EARNED_CONFIRMED // Cleared lock window, added to withdrawable balance
  PAID_OUT         // Debited on payout
  ADJUSTMENT        // Manual admin correction (+/-)
  VOIDED            // Reversal of a fraudulent/cancelled conversion
}

// ----------------------------------------------------------------------------
// COUPON
// ----------------------------------------------------------------------------

model Coupon {
  id              String          @id @default(cuid())
  code            String          @unique // normalized UPPERCASE, e.g. "RAHUL200"

  discountType    DiscountType
  discountValue   Decimal         @db.Decimal(10, 2) // INR flat amount OR percentage (0-100)
  maxDiscountAmount Decimal?      @db.Decimal(10, 2) // cap for PERCENTAGE type, null = uncapped

  // --- Eligibility / bounds -------------------------------------------------
  minBookingAmount Decimal?       @db.Decimal(10, 2) // floor cart value to qualify
  applicableRoomCategories RoomCategory[] @default([ALL])
  firstBookingOnly Boolean        @default(false) // new-tenant-only acquisition codes

  // --- Usage limits ----------------------------------------------------------
  maxTotalRedemptions   Int?      // global cap across all users, null = unlimited
  maxRedemptionsPerUser Int       @default(1)
  currentRedemptions    Int       @default(0) // denormalized counter, updated atomically

  // --- Validity window ---------------------------------------------------
  validFrom       DateTime        @default(now())
  validUntil      DateTime
  status          CouponStatus    @default(PENDING_APPROVAL)

  // --- Ownership / attribution --------------------------------------------
  ownerType       CouponOwnerType @default(SYSTEM)
  ownerId         String?         // User.id — null for SYSTEM coupons
  owner           User?           @relation("CouponOwner", fields: [ownerId], references: [id])

  // Commission the owner earns per successful booking that redeems this code.
  // Independent of the discount given to the booker. Set by Super Admin only.
  commissionType  DiscountType?
  commissionValue Decimal?        @db.Decimal(10, 2)

  // --- Approval trail (for non-admin-submitted requests) --------------------
  requestedById   String?
  requestedBy     User?           @relation("CouponRequestedBy", fields: [requestedById], references: [id])
  requestNote     String?         @db.Text // creator's justification / campaign context
  reviewedById    String?         // Super Admin user id who approved/rejected
  reviewedAt      DateTime?
  rejectionReason String?         @db.Text

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  redemptions     CouponRedemption[]
  referrals       Referral[]

  @@index([status, validUntil])
  @@index([ownerId])
  @@map("coupons")
}

// One row per successful application — enables per-user usage-limit checks
// and prevents replay/race-condition double redemption.
model CouponRedemption {
  id           String   @id @default(cuid())
  couponId     String
  coupon       Coupon   @relation(fields: [couponId], references: [id])
  userId       String   // the booker who redeemed it
  user         User     @relation("CouponRedeemer", fields: [userId], references: [id])
  bookingId    String   @unique // 1:1 with a booking row in your Booking model
  discountApplied Decimal @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  @@unique([couponId, userId, bookingId])
  @@index([userId])
  @@map("coupon_redemptions")
}

// ----------------------------------------------------------------------------
// REFERRAL (funnel tracking: click -> signup -> booking -> payout)
// ----------------------------------------------------------------------------

model Referral {
  id              String          @id @default(cuid())

  referrerId      String          // the person who owns the code/link
  referrer        User            @relation("ReferralsMade", fields: [referrerId], references: [id])

  refereeId       String?         // filled in once the visitor signs up (nullable pre-signup)
  referee         User?           @relation("ReferralsReceived", fields: [refereeId], references: [id])

  couponId        String?         // referral codes are modeled as CREATOR/AFFILIATE/STUDENT coupons
  coupon          Coupon?         @relation(fields: [couponId], references: [id])

  status          ReferralStatus  @default(CLICKED)

  // --- Attribution / anti-abuse -------------------------------------------
  clickSourceIp     String?       // hashed, for fraud heuristics — never store raw for long
  clickUserAgent    String?
  attributionCookie String?       @unique // first-touch cookie id, 30-day rolling window
  isSelfReferral    Boolean       @default(false) // computed & flagged, see controller logic

  // --- Money ------------------------------------------------------------
  bookingId       String?         @unique
  bookingValue    Decimal?        @db.Decimal(10, 2)
  commissionEarned Decimal?       @db.Decimal(10, 2) // snapshot at time of conversion
  payoutLockedUntil DateTime?     // e.g. bookingDate + cancellation window (typically 7-14 days)

  clickedAt       DateTime        @default(now())
  signedUpAt      DateTime?
  bookedAt        DateTime?
  paidAt          DateTime?

  @@index([referrerId, status])
  @@index([attributionCookie])
  @@map("referrals")
}

// ----------------------------------------------------------------------------
// AFFILIATE PROFILE (Creators + Independent Affiliates — non-tenant earners)
// ----------------------------------------------------------------------------

model AffiliateProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])

  personaType     CouponOwnerType // CREATOR | AFFILIATE (STUDENT tenants don't need this row)
  status          AffiliateStatus @default(PENDING_REVIEW)

  displayName     String
  socialLinks     Json?           // { instagram, youtube, website, ... }
  audienceSizeNote String?        // self-reported, informational only

  // --- Balances (all in INR, denormalized for fast dashboard reads) --------
  lifetimeEarned    Decimal       @default(0) @db.Decimal(12, 2)
  pendingBalance    Decimal       @default(0) @db.Decimal(12, 2) // inside payoutLockedUntil window
  availableBalance  Decimal       @default(0) @db.Decimal(12, 2) // withdrawable now
  paidOutTotal      Decimal       @default(0) @db.Decimal(12, 2)

  // --- Payout details --------------------------------------------------------
  payoutMethod    PayoutMethod?
  upiId           String?
  bankAccountName String?
  bankAccountNumber String?       // consider field-level encryption at the app layer
  bankIfsc        String?
  minPayoutThreshold Decimal      @default(500) @db.Decimal(10, 2)

  approvedById    String?         // Super Admin who approved this affiliate
  approvedAt      DateTime?
  rejectionReason String?         @db.Text

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ledgerEntries   PayoutLedgerEntry[]
  payoutRequests  PayoutRequest[]

  @@map("affiliate_profiles")
}

// Immutable audit trail — every balance mutation is a ledger row, never a
// direct field edit. Denormalized balances above are derived/cached from this.
model PayoutLedgerEntry {
  id                  String            @id @default(cuid())
  affiliateProfileId  String
  affiliateProfile    AffiliateProfile  @relation(fields: [affiliateProfileId], references: [id])
  referralId          String?           // link back to the conversion event, if applicable
  type                LedgerEntryType
  amount              Decimal           @db.Decimal(10, 2) // signed: positive credit, negative debit
  note                String?
  createdAt           DateTime          @default(now())

  @@index([affiliateProfileId, createdAt])
  @@map("payout_ledger_entries")
}

model PayoutRequest {
  id                  String            @id @default(cuid())
  affiliateProfileId  String
  affiliateProfile    AffiliateProfile  @relation(fields: [affiliateProfileId], references: [id])
  amount              Decimal           @db.Decimal(10, 2)
  status              String            @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  requestedAt         DateTime          @default(now())
  processedAt         DateTime?
  processedById       String?           // Super Admin
  failureReason       String?

  @@map("payout_requests")
}

